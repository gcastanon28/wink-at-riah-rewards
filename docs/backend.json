
{
  "entities": {
    "Client": {
      "title": "Client",
      "description": "Information about a salon client and their loyalty status.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the client." },
        "email": { "type": "string", "format": "email", "description": "Email address for login." },
        "points": { "type": "number", "description": "Current loyalty point balance." },
        "tier": { "type": "string", "enum": ["New Member", "Lash VIP", "Elite Member"], "description": "Current membership tier." },
        "nextReward": { "type": "number", "description": "Points threshold for the next reward." }
      },
      "required": ["name", "email", "points", "tier"]
    },
    "Reward": {
      "title": "Reward",
      "description": "Available rewards in the loyalty catalog.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Name of the reward." },
        "description": { "type": "string", "description": "Details about the reward." },
        "points_cost": { "type": "number", "description": "Points needed to redeem." },
        "active": { "type": "boolean", "description": "Whether the reward is currently available." }
      },
      "required": ["title", "points_cost", "active"]
    },
    "Redemption": {
      "title": "Redemption",
      "description": "A record of a reward being claimed by a client.",
      "type": "object",
      "properties": {
        "user_id": { "type": "string", "description": "The ID of the client who redeemed." },
        "reward_title": { "type": "string", "description": "The title of the reward redeemed." },
        "points_used": { "type": "number", "description": "Points deducted for this redemption." },
        "created_at": { "type": "string", "format": "date-time", "description": "When the redemption occurred." }
      },
      "required": ["user_id", "reward_title", "points_used", "created_at"]
    }
  },
  "auth": {
    "provider": "supabase",
    "methods": ["email_password"]
  },
  "supabase": {
    "profiles": {
      "schema": "Client",
      "description": "User profile, point balance, tier, and communication preferences. The row id should match auth.users.id."
    },
    "rewards": {
      "schema": "Reward",
      "description": "Catalog of redeemable beauty services."
    },
    "redemptions": {
      "schema": "Redemption",
      "description": "Log of point usage."
    },
    "storage": {
      "avatars": {
        "description": "Profile avatar uploads keyed by user profile id."
      }
    }
  }
}
